        f"r'{STACK_DIR / '.cache' / 'graph_cache.json'}')\n"
        f"hits = a.query_caller({args.fn!r})\n"
        "for h in hits[:200]:\n"
        "    print(f\"  {h['file']}:{h['line']}  in {h['caller_fn']}\")\n"
        "    if h.get('context'):\n"
        "        print(f\"      {h['context']}\")\n"
        "print(f'\\nTotal: {len(hits)} callsites')\n"
    )
    try:
        return subprocess.call([py, "-c", script])
    except FileNotFoundError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        return 2


def cmd_graph_query_action(args) -> int:
    idx = _require_bridge_index()
    if idx is None:
        return 2
    for d in idx.get("domains", []):
        if d.get("domain") != args.domain:
            continue
        for a in d.get("actions", []):
            if a.get("name") == args.action or args.action in (a.get("aliases") or []):
                print(f"domain       : {d['domain']}")
