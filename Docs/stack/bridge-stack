def _require_bridge_index() -> dict | None:
    if not BRIDGE_INDEX_PATH.exists():
        print(f"ERROR: {BRIDGE_INDEX_PATH.name} not found. Run "
              "`bridge-stack rebuild --tier graph` first.",
              file=sys.stderr)
        return None
    try:
        return json.loads(BRIDGE_INDEX_PATH.read_text(encoding="utf-8"))
    except Exception as e:
        print(f"ERROR: {BRIDGE_INDEX_PATH.name} parse failed: {e}",
              file=sys.stderr)
        return None


def cmd_graph_list_domains(_args) -> int:
    idx = _require_bridge_index()
    if idx is None:
        return 2
    for d in idx.get("domains", []):
        print(f"{d['domain']:<24} {len(d.get('actions', [])):>4}  "
              f"{d.get('handler_file', '')}")
    print()
    print(f"Total: {len(idx.get('domains', []))} domains")
    return 0


def cmd_graph_list_actions(args) -> int:
    idx = _require_bridge_index()
    if idx is None:
        return 2
    for d in idx.get("domains", []):
        if d.get("domain") != args.domain:
            continue
        actions = d.get("actions", [])
        print(f"Domain: {args.domain}  (handler: {d.get('handler_file', '?')})")
        print("-" * 60)
        for a in actions:
            fn = a.get("handler_fn") or "(inline)"
            aliases = a.get("aliases") or []
            alias_str = f"  aliases: {aliases}" if aliases else ""
            print(f"  L{a.get('dispatch_line', '?'):>5}  "
                  f"{a.get('name', '?'):<32} -> {fn}{alias_str}")
        print()
        print(f"Total: {len(actions)} actions")
        return 0
    print(f"Domain not found: {args.domain}", file=sys.stderr)
    return 1


def cmd_graph_query_caller(args) -> int:
