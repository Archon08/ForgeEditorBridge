def _load_vector_stats_quick() -> dict | None:
    """Cheap sqlite read so `status` does not pay the model-load cost.

    Returns {} if the DB exists but has no data yet.
    """
    if not VECTOR_DB_PATH.exists():
        return None
    import sqlite3
    try:
        con = sqlite3.connect(str(VECTOR_DB_PATH))
        # Do not load sqlite-vec here; all we need is plain table counts + meta.
        rows = con.execute(
            "SELECT kind, COUNT(*) FROM chunks GROUP BY kind"
        ).fetchall()
        by_kind: dict = {}
        for k, n in rows:
            by_kind[k] = n
        total = con.execute("SELECT COUNT(*) FROM chunks").fetchone()[0]
        meta = dict(con.execute("SELECT key, value FROM meta").fetchall())
        con.close()
        size_mb = round(VECTOR_DB_PATH.stat().st_size / (1024.0 * 1024.0), 2)
        by_kind_str = ", ".join(f"{k}:{v}" for k, v in sorted(by_kind.items()))
        return {
            "chunks_total": total,
            "by_kind": by_kind,
            "by_kind_str": by_kind_str,
            "model_id": meta.get("model_id", "?"),
            "model_dim": int(meta.get("model_dim", "0") or 0),
            "db_size_mb": size_mb,
            "last_build_iso": meta.get("last_build_iso", ""),
        }
    except Exception:
        return None


def _ue_kg_versions() -> list[str]:
    if not UE_KG_ROOT.exists():
        return []
    out: list[str] = []
    for p in UE_KG_ROOT.iterdir():
        if p.is_dir() and (p / "index.sqlite").exists():
            out.append(p.name)
    return sorted(out)


def _ue_kg_manifest_version() -> str | None:
    if not UE_KG_MANIFEST.exists():
        return None
    try:
        m = json.loads(UE_KG_MANIFEST.read_text(encoding="utf-8"))
        return m.get("ue_version")
    except Exception:
        return None


def _load_ue_kg_stats_quick(ue_version: str) -> dict | None:
    """Cheap sqlite read of the ue_kg index (no model load)."""
    idx_path = UE_KG_ROOT / ue_version / "index.sqlite"
    emb_path = UE_KG_ROOT / ue_version / "embeddings.sqlite"
    kg_path = UE_KG_ROOT / ue_version / "kg.pickle"
    if not idx_path.exists():
        return None
    import sqlite3
    try:
        con = sqlite3.connect(str(idx_path))
        n_classes = con.execute("SELECT COUNT(*) FROM classes").fetchone()[0]
        n_members = con.execute("SELECT COUNT(*) FROM members").fetchone()[0]
        n_methods = con.execute(
            "SELECT COUNT(*) FROM members WHERE kind = 'method'").fetchone()[0]
        n_dep = con.execute(
            "SELECT COUNT(*) FROM members WHERE deprecated = 1").fetchone()[0]
        n_modules = con.execute("SELECT COUNT(*) FROM modules").fetchone()[0]
        meta = dict(con.execute("SELECT key, value FROM meta").fetchall())
        con.close()
        emb_count = 0
        if emb_path.exists():
            try:
                ec = sqlite3.connect(str(emb_path))
                emb_count = ec.execute(
                    "SELECT COUNT(*) FROM ue_entities").fetchone()[0]
                ec.close()
            except Exception:
                pass
        kg_size_mb = round(kg_path.stat().st_size / (1024.0 * 1024.0), 2) if kg_path.exists() else 0.0
        emb_size_mb = round(emb_path.stat().st_size / (1024.0 * 1024.0), 2) if emb_path.exists() else 0.0
        idx_size_mb = round(idx_path.stat().st_size / (1024.0 * 1024.0), 2)
        return {
            "ue_version": ue_version,
            "classes": n_classes,
            "members": n_members,
            "methods": n_methods,
            "deprecated_count": n_dep,
            "modules_indexed": n_modules,
            "embeddings": emb_count,
            "last_build_iso": meta.get("last_build_iso", ""),
            "kg_pickle_mb": kg_size_mb,
            "embeddings_mb": emb_size_mb,
            "index_mb": idx_size_mb,
        }
    except Exception:
        return None


def _run_vector_rebuild(force: bool) -> int:
    """Invoke the vector adapter from the venv's Python."""
    py = _pick_python()
    force_lit = "True" if force else "False"
    script = (
        "import sys, json\n"
        f"sys.path.insert(0, r'{STACK_DIR}')\n"
        "from adapters.vector_adapter import VectorAdapter\n"
        f"va = VectorAdapter(r'{STACK_DIR}', r'{VECTOR_DB_PATH}')\n"
        f"stats = va.rebuild_index(force={force_lit})\n"
        "print(json.dumps(stats, indent=2))\n"
    )
    print(f"[rebuild:vector] {py}  (db: {VECTOR_DB_PATH})")
    try:
        return subprocess.call([py, "-c", script])
    except FileNotFoundError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        return 2


def _run_ue_kg_rebuild(ue_version: str | None, force: bool) -> int:
    """Invoke the UE KG adapter from the venv's Python."""
    if not UE_KG_MANIFEST.exists():
        print(f"ERROR: {UE_KG_MANIFEST} not found. Run the manifest generator first "
              "(stack/build_manifest.py).", file=sys.stderr)
        return 2
    if not ue_version:
        ue_version = _ue_kg_manifest_version() or "5.7"
    py = _pick_python()
    force_lit = "True" if force else "False"
    script = (
        "import sys, json\n"
        f"sys.path.insert(0, r'{STACK_DIR}')\n"
        "from adapters.ue_kg_adapter import UEKGAdapter\n"
        f"a = UEKGAdapter(r'{UE_KG_MANIFEST}', '{ue_version}', r'{UE_KG_ROOT}')\n"
        f"stats = a.rebuild(force={force_lit})\n"
        "print(json.dumps(stats, indent=2))\n"
    )
    print(f"[rebuild:ue_kg] {py}  (manifest: {UE_KG_MANIFEST}, version: {ue_version})")
    try:
        return subprocess.call([py, "-c", script])
    except FileNotFoundError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        return 2


def _pick_python() -> str:
    """Prefer the stack venv's Python so tree-sitter is available, then
    fall back to current interpreter."""
    if VENV_PY.exists():
        return str(VENV_PY)
    if VENV_PY_POSIX.exists():
        return str(VENV_PY_POSIX)
    return sys.executable


def _run_graph_generator() -> int:
    """Invoke the generator as a subprocess so it runs under the venv's
    Python. This keeps the CLI callable from any shell without activation."""
    gen = ADAPTERS_DIR / "_bridge_index_generator.py"
    if not gen.exists():
        print(f"ERROR: generator not found at {gen}", file=sys.stderr)
        return 2
    py = _pick_python()
    cmd = [py, str(gen)]
    print(f"[rebuild:graph] {py} {gen}")
    try:
        rc = subprocess.call(cmd)
    except FileNotFoundError as e:
        print(f"ERROR: failed to launch generator: {e}", file=sys.stderr)
        return 2
    return rc


def cmd_rebuild(args) -> int:
    force = bool(getattr(args, "force", False))
    if args.tier in ("graph", "all"):
        rc = _run_graph_generator()
        if rc != 0:
            print(f"[rebuild:graph] generator exited with rc={rc}", file=sys.stderr)
            return rc
        # Chain map regen so INDEX_FRESHNESS reflects the new build.
        print()
        print("[rebuild:graph] chaining `map regen`...")
        rc2 = cmd_map_regen(argparse.Namespace())
        if rc2 != 0:
            print(f"[rebuild:graph] map regen exited with rc={rc2}", file=sys.stderr)
            return rc2
        if args.tier == "graph":
            return 0
    if args.tier in ("vector", "all"):
        rc = _run_vector_rebuild(force=force)
        if rc != 0:
            print(f"[rebuild:vector] rebuild exited with rc={rc}", file=sys.stderr)
            return rc
        print()
        print("[rebuild:vector] chaining `map regen`...")
        rc2 = cmd_map_regen(argparse.Namespace())
        if rc2 != 0:
            print(f"[rebuild:vector] map regen exited with rc={rc2}", file=sys.stderr)
            return rc2
        if args.tier == "vector":
            return 0
    if args.tier in ("ue_kg", "all"):
        ue_version = getattr(args, "ue_version", None)
        rc = _run_ue_kg_rebuild(ue_version, force=force)
        if rc != 0:
            print(f"[rebuild:ue_kg] rebuild exited with rc={rc}", file=sys.stderr)
            return rc
        print()
        print("[rebuild:ue_kg] chaining `map regen`...")
        rc2 = cmd_map_regen(argparse.Namespace())
        if rc2 != 0:
            print(f"[rebuild:ue_kg] map regen exited with rc={rc2}", file=sys.stderr)
            return rc2
        if args.tier == "ue_kg":
            return 0
    if args.tier == "all":
        print("[rebuild:all] graph + vector + ue_kg done.")
        return 0
    print(f"Unknown tier: {args.tier}")
    return 2


# --- Vector (Tier 3) subcommands -------------------------------------------

def cmd_search(args) -> int:
    """Semantic search over the vector index. Delegates to the adapter in
    the venv's Python so sentence-transformers imports cleanly."""
    if not VECTOR_DB_PATH.exists():
        print(f"ERROR: {VECTOR_DB_PATH} not found. Run "
              "`bridge-stack rebuild --tier vector` first.", file=sys.stderr)
        return 2
    py = _pick_python()
    filt: dict = {}
    if getattr(args, "kind", None):
        filt["kind"] = args.kind
    if getattr(args, "domain", None):
        filt["domain"] = args.domain
    filt_lit = repr(filt) if filt else "None"
    k = int(getattr(args, "k", 5) or 5)
    query = args.query
    script = (
        "import sys, json\n"
        f"sys.path.insert(0, r'{STACK_DIR}')\n"
        "from adapters.vector_adapter import VectorAdapter\n"
        f"va = VectorAdapter(r'{STACK_DIR}', r'{VECTOR_DB_PATH}')\n"
        f"hits = va.search({query!r}, k={k}, filter={filt_lit})\n"
        "for i, h in enumerate(hits, 1):\n"
        "    label_parts = []\n"
        "    if h.get('kind'):         label_parts.append(h['kind'])\n"
        "    if h.get('domain'):       label_parts.append(h['domain'])\n"
        "    if h.get('action'):       label_parts.append(h['action'])\n"
        "    if h.get('recipe_id'):    label_parts.append(h['recipe_id'])\n"
        "    label = ' / '.join(label_parts)\n"
        "    print(f\"{i:>2}. [{h['score']:.3f}] {label}\")\n"
        "    line = h.get('line')\n"
        "    loc  = h.get('file') or ''\n"
        "    if line: loc = f\"{loc}:{line}\"\n"
        "    if loc: print(f\"     {loc}\")\n"
        "    snip = h.get('snippet') or ''\n"
        "    if snip: print(f\"     {snip}\")\n"
        "print()\n"
        "print(f'{len(hits)} hit(s).')\n"
    )
    try:
        return subprocess.call([py, "-c", script])
    except FileNotFoundError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        return 2


def _resolve_ue_kg_version(args) -> str:
    v = getattr(args, "ue_version", None)
    if v:
        return v
    versions = _ue_kg_versions()
    if versions:
        return _ue_kg_manifest_version() or versions[0]
    return _ue_kg_manifest_version() or "5.7"


def _spawn_ue_kg(method_call: str, ue_version: str) -> int:
    if not UE_KG_MANIFEST.exists():
        print(f"ERROR: {UE_KG_MANIFEST} not found. Run the manifest generator first.",
              file=sys.stderr)
        return 2
    py = _pick_python()
    script = (
        "import sys, json\n"
        f"sys.path.insert(0, r'{STACK_DIR}')\n"
        "from adapters.ue_kg_adapter import UEKGAdapter\n"
        f"a = UEKGAdapter(r'{UE_KG_MANIFEST}', '{ue_version}', r'{UE_KG_ROOT}')\n"
        f"out = {method_call}\n"
        "print(json.dumps(out, indent=2, default=str))\n"
    )
    try:
        return subprocess.call([py, "-c", script])
    except FileNotFoundError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        return 2


def cmd_ue_kg_query(args) -> int:
    ue_version = _resolve_ue_kg_version(args)
    k = int(getattr(args, "k", 5) or 5)
    q = args.query
    return _spawn_ue_kg(f"a.query({q!r}, k={k})", ue_version)


def cmd_ue_kg_deprecated(args) -> int:
    ue_version = _resolve_ue_kg_version(args)
    cls = getattr(args, "cls", None)
    mod = getattr(args, "module", None)
    cls_lit = repr(cls) if cls else "None"
    mod_lit = repr(mod) if mod else "None"
    return _spawn_ue_kg(f"a.deprecated(class_name={cls_lit}, module={mod_lit})",
                         ue_version)


def cmd_ue_kg_sig(args) -> int:
    ue_version = _resolve_ue_kg_version(args)
    qn = args.qualified_name
    return _spawn_ue_kg(f"a.signature({qn!r})", ue_version)


def cmd_ue_kg_members(args) -> int:
    ue_version = _resolve_ue_kg_version(args)
    cls = args.class_name
    scope = getattr(args, "scope", None) or "public"
    return _spawn_ue_kg(f"a.members({cls!r}, scope={scope!r})", ue_version)


def cmd_ue_kg_callers(args) -> int:
