def cmd_verify(_args) -> int:
    errors: list[str] = []
    warnings: list[str] = []
    domain_index: dict = {}
    # 1) Inventory
    if not INVENTORY_PATH.exists():
        errors.append(f"Missing inventory: {INVENTORY_PATH}")
    else:
        try:
            inv = _load_inventory()
            doms = inv.get("domains", [])
            if len(doms) < 50:
                errors.append(f"Inventory has only {len(doms)} domains; expected >= 50.")
            domain_index = _build_domain_index(inv)
        except Exception as e:
            errors.append(f"Inventory parse error: {e}")
    # 2) Map exists + frontmatter
    if not MAP_PATH.exists():
        errors.append(f"Missing map: {MAP_PATH}")
    elif not re.match(r"\A---\s*\n.*?\n---\s*\n", _read(MAP_PATH), re.DOTALL):
        errors.append(f"{MAP_PATH.name} is missing YAML frontmatter.")
    # 3) Recipes parse + references resolve
    recipe_files = _iter_recipe_files()
    if not recipe_files:
        warnings.append(f"No recipes found in {RECIPES_DIR}")
    for rp in recipe_files:
        if rp.stat().st_size == 0:
            errors.append(f"{rp.name}: empty file")
            continue
        try:
            data = _parse_recipe(rp)
        except Exception as e:
            errors.append(f"{rp.name}: YAML parse failed ({e})")
            continue
        for key in ("id", "goal"):
            if not data.get(key):
                errors.append(f"{rp.name}: missing required top-level key `{key}`")
        deps = data.get("action_dependencies") or []
        pending = "pending_plugin_support" in (data.get("_raw") or "")
        for dep in deps:
            if not isinstance(dep, str):
                continue
            parts = re.split(r"[./]", dep.strip(), maxsplit=1)
            if len(parts) != 2:
                warnings.append(f"{rp.name}: action_dependency `{dep}` not in "
                                "`domain.action` form; skipping resolution.")
                continue
            dom, act = parts
            if not domain_index:
                continue
            actions = domain_index.get(dom)
            if actions is None or act not in actions:
                (warnings if pending else errors).append(
                    f"{rp.name}: action_dependency `{dep}` "
                    f"{'not in inventory (OK: pending_plugin_support).' if pending else 'not found in inventory and recipe is not marked pending_plugin_support.'}"
                )

    # Phase 1: also verify _bridge_index.json if it exists.
    index_status = "-"
    if BRIDGE_INDEX_PATH.exists():
        try:
            gi = json.loads(BRIDGE_INDEX_PATH.read_text(encoding="utf-8"))
            if not gi.get("domains"):
                warnings.append(f"{BRIDGE_INDEX_PATH.name}: no domains extracted.")
            index_status = (f"ok ({gi.get('graph_backend', '?')}, "
                            f"{len(gi.get('domains', []))} domains)")
        except Exception as e:
            errors.append(f"{BRIDGE_INDEX_PATH.name} parse error: {e}")
            index_status = "PARSE ERROR"
    else:
        index_status = "not built (run `bridge-stack rebuild --tier graph`)"

    # Phase 2: verify vector DB if it exists.
    vector_status = "-"
    if VECTOR_DB_PATH.exists():
        vs = _load_vector_stats_quick()
        if vs is None:
            errors.append(f"{VECTOR_DB_PATH.name} could not be opened.")
            vector_status = "PARSE ERROR"
        else:
            # Expected count: actions + recipes + domain_overviews.
            expected = 0
            if BRIDGE_INDEX_PATH.exists():
                try:
                    gi = json.loads(BRIDGE_INDEX_PATH.read_text(encoding="utf-8"))
                    n_actions = sum(len(d.get("actions", []) or [])
                                    for d in gi.get("domains", []))
                    n_domains = len(gi.get("domains", []))
                    expected = n_actions + len(recipe_files) + n_domains
                except Exception:
                    expected = 0
            actual = vs.get("chunks_total", 0)
            if expected and actual != expected:
                warnings.append(
                    f"vector chunks_total ({actual}) != expected ({expected}).")
            # Model dim sanity: the stored value must match something plausible.
            if vs.get("model_dim", 0) <= 0:
                warnings.append("vector DB has no model_dim metadata recorded.")
            vector_status = (f"ok ({vs.get('chunks_total', 0)} chunks, "
                             f"{vs.get('db_size_mb', 0)} MB, "
                             f"model: {vs.get('model_id', '?')})")
    else:
        vector_status = "not built (run `bridge-stack rebuild --tier vector`)"

    # Phase 3: verify UE KG if present.
    ue_kg_status = "-"
    ue_kg_active = _ue_kg_manifest_version()
    if ue_kg_active:
        if not UE_KG_MANIFEST.exists():
            errors.append(f"UE KG manifest missing: {UE_KG_MANIFEST}")
        s = _load_ue_kg_stats_quick(ue_kg_active) if ue_kg_active else None
        if s is None:
            ue_kg_status = (
                f"not built for UE {ue_kg_active} "
                f"(run `bridge-stack rebuild --tier ue_kg --ue-version {ue_kg_active}`)"
            )
        else:
            # Cross-check class count > 0 and module count matches the manifest.
            try:
                manifest = json.loads(UE_KG_MANIFEST.read_text(encoding="utf-8"))
                expected_modules = manifest.get("module_count", 0)
            except Exception:
                expected_modules = 0
            if s["classes"] <= 0:
                errors.append("UE KG has 0 classes - check extractor and manifest.")
            if expected_modules and s["modules_indexed"] != expected_modules:
                warnings.append(
                    f"UE KG modules_indexed ({s['modules_indexed']}) != "
                    f"manifest module_count ({expected_modules})."
                )
            kg_pickle = UE_KG_ROOT / ue_kg_active / "kg.pickle"
            emb_db = UE_KG_ROOT / ue_kg_active / "embeddings.sqlite"
            if not kg_pickle.exists():
                errors.append(f"UE KG pickle missing: {kg_pickle}")
            if not emb_db.exists():
                errors.append(f"UE KG embeddings DB missing: {emb_db}")
            ue_kg_status = (
                f"ok (UE {s['ue_version']}, {s['classes']} classes, "
                f"{s['methods']} methods, {s['deprecated_count']} deprecated, "
                f"{s['modules_indexed']} modules)"
            )

    print("bridge-stack verify")
    print("-" * 40)
    print(f"Inventory   : {'ok' if INVENTORY_PATH.exists() else 'MISSING'}")
    print(f"Map         : {'ok' if MAP_PATH.exists() else 'MISSING'}")
    print(f"Recipes     : {len(recipe_files)} file(s)")
    print(f"Graph index : {index_status}")
    print(f"Vector index: {vector_status}")
    print(f"UE KG       : {ue_kg_status}")
    if not HAVE_YAML:
        print("  note      : PyYAML not installed; using regex fallback.")
    print()
    if warnings:
        print("Warnings:")
        for w in warnings:
            print(f"  - {w}")
        print()
    if errors:
        print("Errors:")
        for e in errors:
            print(f"  - {e}")
        print()
        print("FAIL")
        return 1
    print("PASS")
    return 0


# --- Argparse wiring --------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="bridge-stack",
        description="ForgeEditorBridge cognitive stack orchestrator.",
    )
    sub = p.add_subparsers(dest="cmd", required=True)
    sub.add_parser("init", help="Print onboarding blurb.")
    sub.add_parser("status", help="One-screen stack dashboard.")
    sub.add_parser("verify", help="Sanity checks across all live tiers.")

    p_map = sub.add_parser("map", help="Map (_bridge_map.md) operations.")
    map_sub = p_map.add_subparsers(dest="map_cmd", required=True)
    map_sub.add_parser("regen", help="Regenerate catalog + freshness zones.")

    p_rebuild = sub.add_parser("rebuild", help="Rebuild a tier.")
    p_rebuild.add_argument(
        "--tier", required=True,
        choices=["graph", "vector", "ue_kg", "all"],
        help="Which tier to rebuild.",
    )
    p_rebuild.add_argument(
        "--ue-version", default=None,
        help="UE version for ue_kg builds (e.g. 5.7, 5.8).",
    )
    p_rebuild.add_argument(
        "--force", action="store_true",
        help="Vector tier: nuke and fully re-embed (ignore hash reuse).",
    )

    # Graph query subcommands (Tier 2)
    p_graph = sub.add_parser("graph", help="Tier 2 graph queries.")
    graph_sub = p_graph.add_subparsers(dest="graph_cmd", required=True)
    graph_sub.add_parser("list-domains", help="Print all known domains.")
    g_la = graph_sub.add_parser("list-actions", help="List actions in a domain.")
    g_la.add_argument("domain")
    g_qc = graph_sub.add_parser("query-caller",
                                help="Show callsites of a function.")
    g_qc.add_argument("fn", help="Function name (bare or Class::Method form).")
    g_qa = graph_sub.add_parser("query-action",
                                help="Locate a domain.action in source.")
    g_qa.add_argument("domain")
    g_qa.add_argument("action")
    graph_sub.add_parser("stats", help="Print graph build stats.")

    # Tier 3 semantic search
    p_search = sub.add_parser("search", help="Semantic search over the vector index.")
    p_search.add_argument("query", help="Natural-language search string.")
    p_search.add_argument("--k", type=int, default=5, help="Top-k hits (default 5).")
    p_search.add_argument("--kind", choices=["action", "recipe", "domain_overview"],
                          default=None, help="Restrict to a chunk kind.")
    p_search.add_argument("--domain", default=None,
                          help="Restrict to a specific domain.")

    p_vector = sub.add_parser("vector", help="Tier 3 vector operations.")
    vector_sub = p_vector.add_subparsers(dest="vector_cmd", required=True)
    vector_sub.add_parser("stats", help="Print vector DB stats.")

    # Tier 4 UE KG subcommands
    p_ukg = sub.add_parser("ue-kg", help="Tier 4 UE engine knowledge graph.")
    ukg_sub = p_ukg.add_subparsers(dest="ue_kg_cmd", required=True)
    u_q = ukg_sub.add_parser("query", help="Free-form query against the UE KG.")
    u_q.add_argument("query")
    u_q.add_argument("--k", type=int, default=5)
    u_q.add_argument("--ue-version", default=None)
    u_d = ukg_sub.add_parser("deprecated", help="List deprecated members.")
    u_d.add_argument("--class", dest="cls", default=None,
                     help="Filter by class qualified name.")
    u_d.add_argument("--module", default=None, help="Filter by module name.")
    u_d.add_argument("--ue-version", default=None)
    u_s = ukg_sub.add_parser("sig", help="Look up a signature by qualified name.")
    u_s.add_argument("qualified_name", help="Class::Member or Class.")
    u_s.add_argument("--ue-version", default=None)
    u_m = ukg_sub.add_parser("members", help="List members of a class.")
    u_m.add_argument("class_name")
    u_m.add_argument("--scope", choices=["public", "protected", "private", "all"],
                      default="public")
    u_m.add_argument("--ue-version", default=None)
    u_c = ukg_sub.add_parser("callers", help="Best-effort engine call sites of a member.")
    u_c.add_argument("qualified_name")
    u_c.add_argument("--ue-version", default=None)
    u_st = ukg_sub.add_parser("stats", help="Print UE KG stats for a version.")
    u_st.add_argument("--ue-version", default=None)

    return p


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    if args.cmd == "init":
        return cmd_init(args)
    if args.cmd == "status":
        return cmd_status(args)
    if args.cmd == "verify":
        return cmd_verify(args)
    if args.cmd == "map":
        if args.map_cmd == "regen":
            return cmd_map_regen(args)
        parser.error(f"unknown map subcommand: {args.map_cmd}")
    if args.cmd == "rebuild":
        return cmd_rebuild(args)
    if args.cmd == "graph":
        if args.graph_cmd == "list-domains":
            return cmd_graph_list_domains(args)
        if args.graph_cmd == "list-actions":
            return cmd_graph_list_actions(args)
        if args.graph_cmd == "query-caller":
            return cmd_graph_query_caller(args)
        if args.graph_cmd == "query-action":
            return cmd_graph_query_action(args)
        if args.graph_cmd == "stats":
            return cmd_graph_stats(args)
        parser.error(f"unknown graph subcommand: {args.graph_cmd}")
    if args.cmd == "search":
        return cmd_search(args)
    if args.cmd == "vector":
        if args.vector_cmd == "stats":
            return cmd_vector_stats(args)
        parser.error(f"unknown vector subcommand: {args.vector_cmd}")
    if args.cmd == "ue-kg":
        if args.ue_kg_cmd == "query":
            return cmd_ue_kg_query(args)
        if args.ue_kg_cmd == "deprecated":
            return cmd_ue_kg_deprecated(args)
        if args.ue_kg_cmd == "sig":
            return cmd_ue_kg_sig(args)
        if args.ue_kg_cmd == "members":
            return cmd_ue_kg_members(args)
        if args.ue_kg_cmd == "callers":
            return cmd_ue_kg_callers(args)
        if args.ue_kg_cmd == "stats":
            return cmd_ue_kg_stats(args)
        parser.error(f"unknown ue-kg subcommand: {args.ue_kg_cmd}")
    parser.error(f"unknown command: {args.cmd}")
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
