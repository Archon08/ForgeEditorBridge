#!/usr/bin/env python3
"""bridge-stack - ForgeEditorBridge cognitive stack orchestrator.

Phase 0 scope: Map (Tier 0) and Recipes (Tier 1).
Phase 1 scope: Graph tier (Tier 2) via tree-sitter-cpp.
Phase 2 scope (this revision): Vector tier (Tier 3) via sentence-transformers
    + sqlite-vec. Model: nomic-ai/nomic-embed-text-v2-moe (see adapter).
Tier 4 (ue_kg) remains a stub for Phase 3.

Subcommands:
  init, status, verify
  map regen
  rebuild --tier graph|vector|ue_kg|all [--force]
  graph list-domains | list-actions <domain> | query-caller <fn>
        | query-action <domain> <action> | stats
  search "<query>" [--k N] [--kind action|recipe|domain_overview] [--domain X]
  vector stats

PyYAML is optional (recipes parse fine without it via a regex fallback).
"""

from __future__ import annotations

import argparse
import datetime as _dt
import json
import os
import re
import subprocess
import sys
from pathlib import Path

STACK_DIR = Path(__file__).resolve().parent
DOCS_DIR = STACK_DIR.parent
INVENTORY_PATH = DOCS_DIR / "_inventory.json"
MAP_PATH = DOCS_DIR / "_bridge_map.md"
STATUS_PATH = DOCS_DIR / "_stack_status.md"
RECIPES_DIR = DOCS_DIR / "recipes"
BRIDGE_INDEX_PATH = DOCS_DIR / "_bridge_index.json"
ADAPTERS_DIR = STACK_DIR / "adapters"
VENV_PY = STACK_DIR / ".venv" / "Scripts" / "python.exe"
VENV_PY_POSIX = STACK_DIR / ".venv" / "bin" / "python"
# Tier 3 artifact (gitignored via Docs/.gitignore).
VECTORS_DIR = DOCS_DIR / ".vectors"
VECTOR_DB_PATH = VECTORS_DIR / "chunks.sqlite"
# Tier 4 artifacts (gitignored via Docs/.gitignore). Per-UE-version subdir.
UE_KG_ROOT = DOCS_DIR / "ue_kg"
UE_KG_MANIFEST = STACK_DIR / "ue_kg_manifest.json"

try:
    import yaml  # type: ignore
    HAVE_YAML = True
except ImportError:
    yaml = None  # type: ignore
    HAVE_YAML = False


# --- Helpers ----------------------------------------------------------------

def _now_stamp() -> str:
    return _dt.datetime.now().strftime("%Y-%m-%d %H:%M")


def _read(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def _write(path: Path, content: str) -> None:
    path.write_text(content, encoding="utf-8")


def _load_inventory() -> dict:
    if not INVENTORY_PATH.exists():
        raise FileNotFoundError(f"Inventory not found at {INVENTORY_PATH}")
    return json.loads(_read(INVENTORY_PATH))


def _iter_recipe_files():
    if not RECIPES_DIR.exists():
        return []
    return sorted(p for p in RECIPES_DIR.glob("*.yml") if p.name != "_template.yml")


def _parse_recipe(path: Path) -> dict:
    """Parse a recipe. PyYAML if available, else a shallow regex fallback that
    only extracts the fields Phase 0 actually cares about."""
    text = _read(path)
    if HAVE_YAML:
        data = yaml.safe_load(text) or {}
        if not isinstance(data, dict):
            raise ValueError(f"{path.name}: top-level YAML is not a mapping")
        data["_raw"] = text
        return data
    out: dict = {"_raw": text}
    for key in ("id", "title", "goal"):
        m = re.search(rf"^{key}\s*:\s*(.+?)\s*$", text, re.MULTILINE)
        if m:
            v = m.group(1).strip()
            if len(v) >= 2 and v[0] == v[-1] and v[0] in ("'", '"'):
                v = v[1:-1]
            out[key] = v
    dm = re.search(r"^action_dependencies\s*:\s*\n((?:[ \t]+-[^\n]*\n?)+)",
                   text, re.MULTILINE)
    if dm:
        deps = []
        for line in dm.group(1).splitlines():
            m = re.match(r"\s*-\s*(.+?)\s*$", line)
            if m:
                deps.append(m.group(1).strip().strip('"').strip("'"))
        out["action_dependencies"] = deps
    return out


def _build_domain_index(inv: dict) -> dict:
    """domain name -> set of action names (including aliases)."""
    idx: dict = {}
    for dom in inv.get("domains", []):
        name = dom.get("domain")
        if not name:
            continue
        actions = {a.get("name") for a in dom.get("actions", []) if a.get("name")}
        for a in dom.get("actions", []):
            for alias in a.get("aliases", []) or []:
                actions.add(alias)
        idx[name] = actions
    return idx


def _mtime(path: Path) -> str:
    ts = _dt.datetime.fromtimestamp(path.stat().st_mtime)
    return ts.strftime("%Y-%m-%d %H:%M")


ZONE_PATTERN = re.compile(
    r"(<!--\s*BEGIN:(?P<name>[A-Z_]+)\s*-->)(?P<body>.*?)(<!--\s*END:(?P=name)\s*-->)",
    re.DOTALL,
)


def _rewrite_zone(text: str, zone: str, new_body: str) -> tuple[str, bool]:
    """Replace body between <!-- BEGIN:zone --> and <!-- END:zone -->."""
    hit = {"v": False}

    def _sub(m: re.Match) -> str:
        if m.group("name") != zone:
            return m.group(0)
        hit["v"] = True
        return f"{m.group(1)}\n{new_body.rstrip()}\n{m.group(4)}"

    return ZONE_PATTERN.sub(_sub, text), hit["v"]


def _trim(s: str, n: int) -> str:
    s = re.sub(r"\s+", " ", (s or "").strip())
    return s if len(s) <= n else s[: n - 3] + "..."


# --- Subcommands ------------------------------------------------------------

def cmd_init(_args) -> int:
    print(
        "Phase 0 init: Map and recipes are authored. "
        "Tiers 2-4 not yet wired. Run `bridge-stack status` to see what's live."
    )
    return 0


def cmd_status(_args) -> int:
    info = {"version": "unknown", "handlers": "?", "actions": "?"}
    if INVENTORY_PATH.exists():
        try:
            inv = _load_inventory()
            info["version"] = inv.get("plugin_version", "unknown")
            c = inv.get("counts", {})
            info["handlers"] = c.get("handlers", "?")
            info["actions"] = c.get("actions_distinct", "?")
        except Exception as e:
            info["error"] = str(e)

    map_ok = MAP_PATH.exists()
    status_ok = STATUS_PATH.exists()
    n_recipes = len(_iter_recipe_files())

    # Graph tier status
    graph_status = "pending (Phase 1)"
    graph_stats_line = ""
    if BRIDGE_INDEX_PATH.exists():
        try:
            idx = json.loads(BRIDGE_INDEX_PATH.read_text(encoding="utf-8"))
            s = idx.get("stats", {})
            graph_status = f"live ({idx.get('graph_backend', '?')})"
            graph_stats_line = (f"                   {s.get('domains', 0)} domains, "
                                f"{s.get('actions', 0)} actions, "
                                f"{s.get('nodes', 0)} nodes, "
                                f"{s.get('edges', 0)} edges")
        except Exception:
            pass

    lines = [
        "=" * 60,
        "bridge-stack status",
        "=" * 60,
        f"Docs dir       : {DOCS_DIR}",
        f"Plugin version : {info['version']}",
        f"Handlers       : {info['handlers']}",
        f"Actions        : {info['actions']}",
        "",
        "Tiers:",
        f"  0 Map         : {'live' if map_ok else 'MISSING'} ({MAP_PATH.name})",
        f"  1 Recipes     : {'live' if n_recipes else 'empty'} ({n_recipes} files)",
        f"  2 Graph       : {graph_status}",
    ]
    if graph_stats_line:
        lines.append(graph_stats_line)
    # Vector tier status
    vector_status = "pending (Phase 2)"
    vector_stats_line = ""
    if VECTOR_DB_PATH.exists():
        try:
            vstats = _load_vector_stats_quick()
            if vstats:
                vector_status = f"live ({vstats.get('model_id', '?')})"
                vector_stats_line = (
                    f"                   {vstats.get('chunks_total', 0)} chunks"
                    f" ({vstats.get('by_kind_str', '')}),"
                    f" {vstats.get('db_size_mb', 0)} MB")
        except Exception:
            pass
    lines.append(f"  3 Vector      : {vector_status}")
    if vector_stats_line:
        lines.append(vector_stats_line)
    # UE KG (Tier 4) status
    ue_kg_status = "pending (Phase 3)"
    ue_kg_lines: list[str] = []
    versions = _ue_kg_versions()
    if versions:
        active = _ue_kg_manifest_version() or versions[0]
        s = _load_ue_kg_stats_quick(active)
        if s:
            ue_kg_status = f"live (UE {s['ue_version']})"
            ue_kg_lines.append(
                f"                   {s['classes']} classes, {s['methods']} methods, "
                f"{s['deprecated_count']} deprecated, {s['modules_indexed']} modules"
            )
            ue_kg_lines.append(
                f"                   {s['embeddings']} embeddings, "
                f"index={s['index_mb']} MB, kg={s['kg_pickle_mb']} MB, emb={s['embeddings_mb']} MB"
            )
        if len(versions) > 1:
            other = [v for v in versions if v != active]
            ue_kg_lines.append(f"                   other versions: {', '.join(other)}")
    lines.append(f"  4 UE KG       : {ue_kg_status}")
    lines.extend(ue_kg_lines)
    lines += [
        "",
        f"Last map edit  : {_mtime(MAP_PATH) if map_ok else '-'}",
        f"Last status    : {_mtime(STATUS_PATH) if status_ok else '-'}",
        "",
        (f"See {STATUS_PATH.name} for the dashboard details." if status_ok
         else f"(_stack_status.md not found at {STATUS_PATH})"),
    ]
    print("\n".join(lines))
    return 0


def cmd_map_regen(_args) -> int:
    if not MAP_PATH.exists():
        print(f"ERROR: {MAP_PATH} does not exist yet. Author the Map first "
              "with <!-- BEGIN:X --> / <!-- END:X --> zone markers for "
              "DOMAIN_CATALOG, RECIPE_CATALOG, INDEX_FRESHNESS.",
              file=sys.stderr)
        return 2
    inv = _load_inventory()
    text = _read(MAP_PATH)
    # DOMAIN_CATALOG
    rows = ["| domain | handler file | actions | purpose |", "|---|---|---:|---|"]
    for dom in sorted(inv.get("domains", []), key=lambda d: d.get("domain", "")):
        rows.append(
            f"| {dom.get('domain', '?')} | {dom.get('handler_file', '?')} | "
            f"{len(dom.get('actions', []))} | "
            f"{_trim(dom.get('purpose', '').replace('|', '\\|'), 140)} |")
    text, hit_dc = _rewrite_zone(text, "DOMAIN_CATALOG", "\n".join(rows))
    # RECIPE_CATALOG
    rows = ["| id | title | goal |", "|---|---|---|"]
    recipe_files = _iter_recipe_files()
    for rp in recipe_files:
        try:
            d = _parse_recipe(rp)
        except Exception as e:
            rows.append(f"| `{rp.name}` | PARSE ERROR | {e} |")
            continue
        rid = d.get("id", rp.stem)
        title = (d.get("title", "") or "").replace("|", "\\|")
        goal = _trim((d.get("goal", "") or "").replace("|", "\\|"), 160)
        rows.append(f"| `{rid}` | {title} | {goal} |")
    text, hit_rc = _rewrite_zone(text, "RECIPE_CATALOG", "\n".join(rows))
    # INDEX_FRESHNESS
    stamp = _now_stamp()
    # Graph tier: read from _bridge_index.json if present.
    graph_row = "| 2 Graph | - | pending Phase 1 |"
    if BRIDGE_INDEX_PATH.exists():
        try:
            gi = json.loads(BRIDGE_INDEX_PATH.read_text(encoding="utf-8"))
            gstamp = (gi.get("generated_at", "") or "").replace("T", " ").rstrip("Z")[:16]
            backend = gi.get("graph_backend", "?")
            gs = gi.get("stats", {})
            graph_row = (f"| 2 Graph | {gstamp or stamp} | "
                         f"`bridge-stack rebuild --tier graph` (backend: {backend}, "
                         f"{gs.get('domains', '?')} domains / {gs.get('actions', '?')} actions) |")
        except Exception:
            pass
    # Vector tier row: read from .vectors/chunks.sqlite if present.
    vector_row = "| 3 Vector | - | pending Phase 2 |"
    vstats = _load_vector_stats_quick()
    if vstats:
        vstamp = (vstats.get("last_build_iso", "") or "").replace("T", " ").rstrip("Z")[:16]
        vector_row = (f"| 3 Vector | {vstamp or stamp} | "
                      f"`bridge-stack rebuild --tier vector` "
                      f"(model: {vstats.get('model_id', '?')}, "
                      f"{vstats.get('chunks_total', 0)} chunks, "
                      f"{vstats.get('db_size_mb', 0)} MB) |")
    # UE KG row.
    ue_kg_row = "| 4 UE KG | - | pending Phase 3 |"
    versions = _ue_kg_versions()
    if versions:
        active = _ue_kg_manifest_version() or versions[0]
        us = _load_ue_kg_stats_quick(active)
        if us:
            ustamp = (us.get("last_build_iso", "") or "").replace("T", " ").rstrip("Z")[:16]
            ue_kg_row = (f"| 4 UE KG | {ustamp or stamp} | "
                         f"`bridge-stack rebuild --tier ue_kg --ue-version {active}` "
                         f"(UE {us['ue_version']}, {us['classes']} classes, "
                         f"{us['methods']} methods, {us['deprecated_count']} deprecated, "
                         f"{us['modules_indexed']} modules) |")
    fresh = "\n".join([
        "| tier | last built | source |", "|---|---|---|",
        f"| 0 Map | {stamp} | hand-authored + `bridge-stack map regen` |",
        f"| 1 Recipes | {stamp} | `recipes/*.yml` |",
        graph_row,
        vector_row,
        ue_kg_row,
    ])
    text, hit_if = _rewrite_zone(text, "INDEX_FRESHNESS", fresh)
    missing = [z for z, h in (("DOMAIN_CATALOG", hit_dc),
                              ("RECIPE_CATALOG", hit_rc),
                              ("INDEX_FRESHNESS", hit_if)) if not h]
    if missing:
        print(
            f"WARN: map zones not found in {MAP_PATH.name}: {', '.join(missing)}. "
            "Add <!-- BEGIN:ZONE --> / <!-- END:ZONE --> markers to enable regen.",
            file=sys.stderr,
        )

    _write(MAP_PATH, text)
    print(f"Regenerated: {MAP_PATH.name}")
    print(f"  domains : {len(inv.get('domains', []))}")
    print(f"  recipes : {len(recipe_files)}")
    print(f"  stamped : {stamp}")
    return 1 if missing else 0


